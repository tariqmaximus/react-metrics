{
  "name": "metrics-data",
  "version": "1.0.0",
  "description": "Reusable React metrics data table with table, grid and pipeline views",
  "main": "dist/metrics-data.umd.js",
  "module": "dist/metrics-data.es.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/metrics-data.es.js",
      "require": "./dist/metrics-data.umd.js",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "MetricsData.d.ts"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "bootstrap-icons": "^1.11.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.1"
  },
  "keywords": [
    "react",
    "table",
    "metrics",
    "metrics-data",
    "data-grid",
    "pipeline"
  ],
  "author": "Tariq Mehmood Jarral",
  "license": "MIT"
}